---
import '../styles/global.scss'
import '../styles/daylight.scss'
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>nao.world</title>
	</head>

	<body class="day-1">
		<div id="cursor"></div>
		<div id="hover-image-self" class="hover-image-target">
			<img src="/self.jpg">
		</div>

		<div id="root">
			<div class="pane pane-left">
				<div class="pane-left__header">
					<h1>nao.world</h1>
					<nav>
						<button class="text" data-view="bio">bio</button>
					</nav>
				</div>

				<section class="pane-left__main">
					<p>
						I am a <span class="hover-image" data-image="self">human being</span> based in Tokyo who <button class="text" data-view="code">codes</button>, <button class="text" data-view="language">translates</button>, and dabbles in various things.
					</p>
					<p>
						I am interested in randomness, play, places, light, and sound.
					</p>
				</section>

				<section class="pane-left__bottom">
					<p>
						This website was lovingly hand-coded with pure <a href="https://html.energy/" target="_blank">HTML energy</a>.
					</p>
					<p>Last updated: 2026 June 13 <a href="https://github.com/naobot/naomi-personal" target="_blank">[source]</a></p>
				</section>
			</div>

			<div class="pane pane-middle pane-middle--grow pane--togglable" data-panetype="middle" id="bio">
				<h2>naomi cui</h2>

				<div class="timeline">
					<div class="timeline__row">
						<div>1992</div>
						<div>born in Toronto</div>
					</div>
					<div class="timeline__row">
						<div>2010-2015</div>
						<div>Computer Science & Linguistics, University of Toronto</div>
					</div>
					<div class="timeline__row">
						<div>2017-2018</div>
						<div>Kyoto Institute of Culture & Language
						</div>
					</div>
					<div class="timeline__row">
						<div>2024</div>
						<div>moved to Tokyo</div>
					</div>
				</div>
			</div>

			<div class="pane pane-middle pane--togglable" data-panetype="middle" id="code">
				<h2>Code</h2>
				<p>
					<ul>
						<li>
							<button class="text" data-view="tools">
								tools
							</button>
						</li>
						<li>
							<button class="text" data-view="doodles">
								doodles
							</button>
						</li>
						<li>
							<button class="text" data-view="collabs">
								collabs
							</button>
						</li>
					</ul>
				</p>
			</div>

			<div class="pane pane-middle pane-middle--grow pane--togglable" data-panetype="middle" id="language">
				<h2>Language</h2>
				<p>
					I am a native speaker of <strong>English</strong>, heritage speaker of <strong>Mandarin Chinese</strong>, and currently live and work in <strong>Japanese</strong>. I also speak conversational <strong>French</strong> and have dabbled in <strong>Korean</strong>.
				</p>
				<p>
					I used to be a <strong>professional translator</strong> of <strong>Japanese to English</strong> and occasionally <strong>Chinese to English</strong>.
				</p>
				<p>
					In 2019, I wrote and co-created an <a href="https://chickensoupcomic.com/" target="_blank" class="link-external">interactive bilingual children's comic</a>.
				</p>
			</div>

			<div class="pane pane-right pane--togglable" data-panetype="right" id="tools">
				<p>
					Here are some somewhat useful things I have created. I will add descriptions soon. For now you can just click through and look.
				</p>
				<p>
					<ul>
						<li>
							<a href="https://tomodex-phi.vercel.app/" target="_blank">
								Tomodex
							</a>
						</li>
						<li>
							<a href="https://kaki-cms.vercel.app/" target="_blank">Kaki CMS</a>
						</li>
						<li>
							<a href="https://moneylogs-89ebf.web.app/" target="_blank">moneylogs</a>
						</li>
					</ul>
				</p>
			</div>

			<div class="pane pane-right pane--togglable" data-panetype="right" id="doodles">
				<p>
					These are some small-scale web-based dabblings and experiments.
				</p>
				<p>
					<ul>
						<li>
							modal experiment 1 <em>(sharing soon)</em>
						</li>
					</ul>
				</p>
			</div>

			<div class="pane pane-right pane--togglable" data-panetype="right" id="collabs">
				<p>
					Here are some projects I have contributed to as a web developer. If you are a creator with web needs, feel free to reach out. Let's work together.
				</p>
				<p>
					<ul>
						<li>
							<a href="https://amylam.me/projects/make-believe-bathroom.htm" target="_blank">Make-Believe Bathroom</a>
						</li>
						<li>
							<a href="https://www.amygottung.com/" target="_blank">Amy Gottung</a>
						</li>
					</ul>
				</p>
			</div>
		</div>
	</body>
</html>

<script>
	/* panel toggle */
  const buttons = document.querySelectorAll<HTMLElement>('button[data-view]');
  const allPanes = document.querySelectorAll<HTMLElement>('.pane--togglable');

  allPanes.forEach(pane => pane.style.display = 'none');

	buttons.forEach(button => {
	  button.addEventListener('click', () => {
	    const target = button.dataset.view;
	    if (!target) return;

	    const targetPane = document.getElementById(target);
	    if (!targetPane) return;

	    const panetype = targetPane.dataset.panetype;
	    const isVisible = targetPane.style.display !== 'none';

	    // If middle pane, also hide all right panes
	    if (panetype === 'middle') {
	    	const rightPanes = document.querySelectorAll<HTMLElement>('.pane-right');
	    	rightPanes.forEach(pane => pane.style.display = 'none');
	    }

	    // Hide all togglable panes of the same type
	    document.querySelectorAll<HTMLElement>(`.pane--togglable[data-panetype="${panetype}"]`)
	      .forEach(pane => pane.style.display = 'none');

	    if (!isVisible) targetPane.style.display = 'block';
	  });
	});
</script>

<script>
	/* cursor */
	const cursor = document.getElementById('cursor');
	let activeHoverImage: HTMLElement | null = null;

	document.addEventListener('mousemove', (e) => {
	  if (!cursor) return;
	  cursor.style.translate = `${e.clientX - 16}px ${e.clientY - 16}px`;

	  if (activeHoverImage) {
	    activeHoverImage.style.left = `${e.clientX}px`;
	    activeHoverImage.style.top = `${e.clientY}px`;
	  }
	});

	document.querySelectorAll<HTMLElement>('.hover-image').forEach(span => {
	  span.addEventListener('mouseenter', () => {
	    const imageId = span.dataset.image;
	    if (!imageId) return;
	    const imageEl = document.getElementById(`hover-image-${imageId}`);
	    if (!imageEl) return;
	    activeHoverImage = imageEl;
	    imageEl.style.display = 'block';
	  });

	  span.addEventListener('mouseleave', () => {
	    if (activeHoverImage) {
	      activeHoverImage.style.display = 'none';
	      activeHoverImage = null;
	    }
	  });
	});

	/* daylight setter */
	const bodyElement = document.querySelector('body');

	setInterval(() => {
		const now = new Date();
		const currentHour = now.getHours();
		// const currentHour = now.getMinutes() % 24;

		if (bodyElement?.className && bodyElement.className !== `day-${currentHour}`) {
			bodyElement.className = `day-${currentHour}`;
		}
	}, 1000);
</script>
